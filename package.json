{
  "name": "vketreal-image-creator",
  "version": "1.0.0",
  "description": "VketReal 2025 Winter参加表明カードジェネレーター",
  "main": "index.html",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/input.css -o ./tailwind.css --watch",
    "build:css:prod": "npx tailwindcss -i ./src/input.css -o ./tailwind.css --minify",
    "serve": "npx serve",
    "dev": "pnpm build:css:prod & pnpm serve",
    "lint": "eslint --fix 'src/**/*.{js,ts}'",
    "lint-fix": "eslint --fix './src/**/*.{js,ts}' && prettier --write './src /**/*.{js,ts}'"
  },
  "keywords": [
    "VketReal",
    "card-generator",
    "tailwindcss"
  ],
  "author": "VketReal Team",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    
  }
}